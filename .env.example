# === Required ===
# Google Gemini API key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-placeholder-gemini-key

# PostgreSQL connection string (Compose publishes the container on localhost:5433)
DATABASE_URL=postgresql+asyncpg://jobengine@localhost:5433/jobengine

# === Optional ===
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Verification pipeline timeout per URL (seconds)
VERIFICATION_TIMEOUT_SECONDS=8

# React frontend API URL (only needed if not using default localhost:8000)
REACT_APP_API_URL=http://localhost:8000
