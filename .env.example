# === Required ===
# Google Gemini API key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://jobengine:jobengine@localhost:5432/jobengine

# === Optional ===
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Verification pipeline timeout per URL (seconds)
VERIFICATION_TIMEOUT_SECONDS=8

# React frontend API URL (only needed if not using default localhost:8000)
REACT_APP_API_URL=http://localhost:8000
