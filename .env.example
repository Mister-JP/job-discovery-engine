# ============================================
# Job Discovery Engine - Environment Variables
# ============================================
# Copy this file to .env and fill in the required values.
# The repo-level .env is loaded by both local backend and frontend workflows.
# cp .env.example .env

# === REQUIRED ===

# Google Gemini API key used by the backend search pipeline.
# Get one from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Async SQLAlchemy connection string used by the backend runtime.
# Local Docker Compose publishes Postgres on localhost:5433.
# Format: postgresql+asyncpg://user[:password]@host:port/database
DATABASE_URL=postgresql+asyncpg://jobengine@localhost:5433/jobengine

# === OPTIONAL (with defaults) ===

# Preferred runtime environment name.
# Default: development
# Production values such as production or prod switch the default log format to json.
ENVIRONMENT=development

# Backward-compatible alias for ENVIRONMENT.
# Only used when ENVIRONMENT is unset.
APP_ENV=

# Logging level.
# Allowed values: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# Log output format override.
# Allowed values: readable, json
# Default: readable in development, json in production
# Leave blank to use the environment-based default.
LOG_FORMAT=

# Verification pipeline timeout per URL in seconds.
# Default: 8
VERIFICATION_TIMEOUT_SECONDS=8

# Backend API base URL used by the React frontend.
# Default: http://localhost:8000
REACT_APP_API_URL=http://localhost:8000
